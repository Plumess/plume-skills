#!/usr/bin/env bash
# plume-skills PreCompact hook — dual-insurance Layer 1
#
# Single marker design: .save-pending-<session-id>-<marker-id>
#   phase=save     → first attempt, block compact
#   phase=recovery → second attempt, allow compact
#
# First attempt:  no marker for this session → create phase=save, block compact
#                 → UserPromptSubmit injects [CONTEXT-SAVE-URGENT marker-id=<mid>]
#                 → Claude saves with full context (highest quality)
# Second attempt: marker still exists → update phase=recovery, allow compact
#                 → UserPromptSubmit injects [CONTEXT-RECOVERY marker-id=<mid>]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUME_ROOT="$(dirname "$SCRIPT_DIR")"
MARKER_DIR="$PLUME_ROOT/data"

# Read hook input — parse with sed (no python3)
HOOK_INPUT=""
if [ ! -t 0 ]; then
  HOOK_INPUT="$(cat)"
fi

CWD=""
SESSION_ID=""
if [ -n "$HOOK_INPUT" ]; then
  CWD="$(printf '%s' "$HOOK_INPUT" | sed -n 's/.*"cwd" *: *"\([^"]*\)".*/\1/p')"
  SESSION_ID="$(printf '%s' "$HOOK_INPUT" | sed -n 's/.*"session_id" *: *"\([^"]*\)".*/\1/p')"
  SESSION_ID="${SESSION_ID:0:8}"
fi
if [ -z "$CWD" ]; then
  CWD="$(pwd)"
fi
if [ -z "$SESSION_ID" ]; then
  SESSION_ID="unknown"
fi

SLUG="$(echo "$CWD" | sed 's|/|-|g')"
mkdir -p "$MARKER_DIR"

# Find existing marker for this session
EXISTING="$(ls "$MARKER_DIR"/.save-pending-"${SESSION_ID}"-* 2>/dev/null | head -1 || true)"

if [ -n "$EXISTING" ]; then
  # Second attempt — save didn't complete. Update phase to recovery, allow compact.
  sed -i 's/^phase=save$/phase=recovery/' "$EXISTING"
  echo '{}'
else
  # First attempt — generate marker-id, block compact, request save.
  # Read timezone from config.yml (pure grep, no python/yaml)
  TZ_NAME="$(grep -oP '^\s*timezone:\s*"\K[^"]+' "$PLUME_ROOT/config.yml" 2>/dev/null || echo 'Asia/Shanghai')"
  MARKER_ID="$(TZ="$TZ_NAME" date +%Y%m%d-%H%M)"

  cat > "$MARKER_DIR/.save-pending-${SESSION_ID}-${MARKER_ID}" <<EOF
phase=save
slug=$SLUG
cwd=$CWD
EOF
  cat <<'EOF'
{"decision": "block", "reason": "Blocking compact to allow context-keeper save first."}
EOF
fi
