#!/usr/bin/env bash
# plume-skills SessionStart hook
# Injects using-plume guide + PLUME_ROOT into conversation context.
# Compact recovery is handled by pre-compact + user-prompt-submit hooks.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUME_ROOT="$(dirname "$SCRIPT_DIR")"
SKILL_FILE="$PLUME_ROOT/skills/using-plume/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
  echo '{}'
  exit 0
fi

# Inject PLUME_ROOT so all skills can locate vendor/ and data/
SKILL_CONTENT="[PLUME_ROOT: $PLUME_ROOT]

$(cat "$SKILL_FILE")"

# JSON-escape the content
ESCAPED="$(printf '%s' "$SKILL_CONTENT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '%s' "$SKILL_CONTENT" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | awk '{printf "%s\\n", $0}')"

cat <<EOF
{
  "hookSpecificOutput": {
    "additionalContext": $ESCAPED
  }
}
EOF
