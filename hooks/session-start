#!/usr/bin/env bash
# plume-skills SessionStart hook
# Injects hooks/principles.md (always-on Plume behavior principles) + PLUME_ROOT signal.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUME_ROOT="$(dirname "$SCRIPT_DIR")"
PRINCIPLES_FILE="$SCRIPT_DIR/principles.md"

if [ ! -f "$PRINCIPLES_FILE" ]; then
  echo '{}'
  exit 0
fi

# Prepend PLUME_ROOT signal to principles content
INJECTED="[PLUME_ROOT: $PLUME_ROOT]

$(cat "$PRINCIPLES_FILE")"

# JSON-escape via python3 (needed for Unicode: CJK, em-dash, arrows)
ESCAPED="$(printf '%s' "$INJECTED" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')"

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": $ESCAPED
  }
}
EOF
