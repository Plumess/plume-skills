#!/usr/bin/env bash
# plume-skills UserPromptSubmit hook
# Functions:
# 1. Always: inject PLUME_ROOT
# 2. Marker phase=save → [CONTEXT-SAVE-URGENT marker-id=<mid>]
# 3. Marker phase=recovery → [CONTEXT-RECOVERY marker-id=<mid>]
# 4. Digest auto-sense: triggers on first session after remind_at time → [DIGEST-HINT] or [DIGEST-AUTO]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUME_ROOT="$(dirname "$SCRIPT_DIR")"
CONFIG="$PLUME_ROOT/config.yml"

# Read hook input — parse with pure bash (avoid python3 for simple JSON)
HOOK_INPUT=""
if [ ! -t 0 ]; then
  HOOK_INPUT="$(cat)"
fi

CWD=""
SESSION_ID=""
if [ -n "$HOOK_INPUT" ]; then
  CWD="$(printf '%s' "$HOOK_INPUT" | sed -n 's/.*"cwd" *: *"\([^"]*\)".*/\1/p')"
  SESSION_ID="$(printf '%s' "$HOOK_INPUT" | sed -n 's/.*"session_id" *: *"\([^"]*\)".*/\1/p')"
  SESSION_ID="${SESSION_ID:0:8}"
fi
if [ -z "$CWD" ]; then
  CWD="$(pwd)"
fi
if [ -z "$SESSION_ID" ]; then
  SESSION_ID="unknown"
fi

SLUG="$(echo "$CWD" | sed 's|/|-|g')"
CLAUDE_PROJECTS="$HOME/.claude/projects"
MARKER_DIR="$PLUME_ROOT/data"

CONTEXT_PARTS=()

# --- Always: inject PLUME_ROOT ---
CONTEXT_PARTS+=("[PLUME_ROOT: $PLUME_ROOT]")

# --- Marker signal: single .save-pending-<sid>-<mid> with phase field ---
MARKER_HIT=false
MARKER_FILE="$(ls "$MARKER_DIR"/.save-pending-"${SESSION_ID}"-* 2>/dev/null | head -1 || true)"
if [ -n "$MARKER_FILE" ]; then
  MARKER_HIT=true
  # Extract marker-id from filename: .save-pending-<sid>-<marker-id> → last YYYYMMDD-HHMM
  MARKER_ID="$(basename "$MARKER_FILE" | sed "s/^\.save-pending-${SESSION_ID}-//")"
  # Read phase from file
  PHASE="$(grep -oP '^phase=\K.*' "$MARKER_FILE" 2>/dev/null || echo 'save')"

  if [ "$PHASE" = "recovery" ]; then
    CONTEXT_PARTS+=("[CONTEXT-RECOVERY marker-id=$MARKER_ID] Session was compacted. Call context-keeper to SAVE fallback then RESTORE.")
  else
    CONTEXT_PARTS+=("[CONTEXT-SAVE-URGENT marker-id=$MARKER_ID] Compact was blocked to allow saving. Call context-keeper SAVE immediately.")
  fi
fi

# --- Digest auto-sense (time-gated: only near remind_at) ---
# Skip entirely if compact signals are active
if [ "$MARKER_HIT" = false ]; then

  # Quick bash-only time check — skip everything if before 08:00
  HOUR_NOW=$(date +%H)
  if [ "$HOUR_NOW" -ge 8 ] && [ -f "$CONFIG" ]; then

    # Single python3 call: read config + compute time + evaluate digest trigger
    # Output format: NOW_MIN|TZ_NAME|DEFAULT_SCOPE|AUTO_GENERATE|TODAY|PAST_REMIND
    DIGEST_RESULT="$(python3 -c "
import datetime, zoneinfo, sys
try:
    import yaml
    c = yaml.safe_load(open('$CONFIG'))
except Exception:
    print('|||||||skip')
    sys.exit(0)

tz_name = c.get('locale', {}).get('timezone', 'Asia/Shanghai')
try:
    now = datetime.datetime.now(zoneinfo.ZoneInfo(tz_name))
except Exception:
    now = datetime.datetime.now()
now_min = now.hour * 60 + now.minute
today = now.strftime('%Y-%m-%d')

if now_min < 480:
    print('|||||||skip')
    sys.exit(0)

d = c.get('digest', {})
scope = d.get('default_scope', '')
auto = str(d.get('auto_generate', False))
remind_times = d.get('remind_at', [])

past = 'false'
for t in remind_times:
    parts = str(t).split(':')
    if len(parts) == 2:
        rt = int(parts[0]) * 60 + int(parts[1])
        if now_min >= rt:
            past = 'true'
            break

print(f'{now_min}|{tz_name}|{scope}|{auto}|{today}|{past}')
" 2>/dev/null || echo "|||||||skip")"

    if [ "$DIGEST_RESULT" != "|||||||skip" ]; then
      IFS='|' read -r NOW_MIN TZ_NAME DEFAULT_SCOPE AUTO_GENERATE TODAY PAST_REMIND <<< "$DIGEST_RESULT"

      if [ "$PAST_REMIND" = "true" ] && [ -n "$DEFAULT_SCOPE" ]; then
        JOURNAL="$PLUME_ROOT/data/journal/${TODAY}.md"
        HINT_MARKER="$PLUME_ROOT/data/digest-hint/$TODAY"

        if [ ! -f "$JOURNAL" ] && [ ! -f "$HINT_MARKER" ]; then
          HAS_ACTIVITY=false
          if [ -d "$CLAUDE_PROJECTS" ]; then
            for projdir in "$CLAUDE_PROJECTS"/*/; do
              dirname="$(basename "$projdir")"
              if echo "$dirname" | grep -qi "$DEFAULT_SCOPE"; then
                if find "$projdir" -maxdepth 1 -name "*.jsonl" -newermt "$TODAY" -print -quit 2>/dev/null | grep -q .; then
                  HAS_ACTIVITY=true
                  break
                fi
              fi
            done
          fi

          if [ "$HAS_ACTIVITY" = true ]; then
            mkdir -p "$PLUME_ROOT/data/digest-hint"
            touch "$HINT_MARKER"
            if [ "$AUTO_GENERATE" = "True" ]; then
              CONTEXT_PARTS+=("[DIGEST-AUTO] Auto-generate daily report now. Scope: $DEFAULT_SCOPE")
            else
              CONTEXT_PARTS+=("[DIGEST-HINT] Active sessions today (scope: $DEFAULT_SCOPE), no daily report yet.")
            fi
          fi
        fi
      fi
    fi
  fi
fi

# --- Output ---
if [ ${#CONTEXT_PARTS[@]} -eq 0 ]; then
  echo '{}'
  exit 0
fi

FULL_MSG="$(printf '%s\n' "${CONTEXT_PARTS[@]}")"

# JSON-escape with pure bash
ESCAPED="$(printf '%s' "$FULL_MSG" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e 's/\t/\\t/g' | awk '{printf "%s\\n", $0}' | sed 's/\\n$//')"

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "$ESCAPED"
  }
}
EOF
