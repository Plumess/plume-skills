#!/usr/bin/env bash
# plume-skills UserPromptSubmit hook
# Functions:
# 1. Always: inject PLUME_ROOT
# 2. Pre-compact save: .save-pending-<session> → [CONTEXT-SAVE-URGENT]
# 3. Compact recovery: .compact-marker-<session> → [CONTEXT-RECOVERY]
# 4. Digest auto-sense: triggers on first session after remind_at time → [DIGEST-HINT] or [DIGEST-AUTO]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUME_ROOT="$(dirname "$SCRIPT_DIR")"
CONFIG="$PLUME_ROOT/config.yml"

# Read hook input
HOOK_INPUT=""
if [ ! -t 0 ]; then
  HOOK_INPUT="$(cat)"
fi

CWD=""
SESSION_ID=""
if [ -n "$HOOK_INPUT" ]; then
  CWD="$(echo "$HOOK_INPUT" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("cwd",""))' 2>/dev/null || true)"
  SESSION_ID="$(echo "$HOOK_INPUT" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("session_id","")[:8])' 2>/dev/null || true)"
fi
if [ -z "$CWD" ]; then
  CWD="$(pwd)"
fi
if [ -z "$SESSION_ID" ]; then
  SESSION_ID="unknown"
fi

SLUG="$(echo "$CWD" | sed 's|/|-|g')"
CLAUDE_PROJECTS="$HOME/.claude/projects"

CONTEXT_PARTS=()

# --- Always: inject PLUME_ROOT ---
CONTEXT_PARTS+=("[PLUME_ROOT: $PLUME_ROOT]")

# --- Pre-compact save signal (session-scoped) ---
SAVE_PENDING="$PLUME_ROOT/data/.save-pending-$SESSION_ID"
if [ -f "$SAVE_PENDING" ]; then
  CONTEXT_PARTS+=("[CONTEXT-SAVE-URGENT] Compact was blocked to allow saving. Call context-keeper SAVE immediately — next compact attempt will proceed without blocking.")
fi

# --- Compact recovery (session-scoped) ---
COMPACT_MARKER="$PLUME_ROOT/data/.compact-marker-$SESSION_ID"
if [ -f "$COMPACT_MARKER" ]; then
  MARKER_SLUG=""
  while IFS='=' read -r key value; do
    case "$key" in
      slug) MARKER_SLUG="$value" ;;
    esac
  done < "$COMPACT_MARKER"

  rm -f "$COMPACT_MARKER"

  CONTEXT_DIR="$CLAUDE_PROJECTS/$MARKER_SLUG/plume-context"
  CONTEXT_PARTS+=("[CONTEXT-RECOVERY] Session was compacted. Restore task state now.
- Context dir: $CONTEXT_DIR
- CONTEXT-INDEX: $CONTEXT_DIR/CONTEXT-INDEX.md
- Call the context-keeper skill to restore.")
fi

# --- Digest auto-sense (time-gated: only near remind_at) ---
# Skip entirely if compact signals are active
if [ ! -f "$SAVE_PENDING" ] && [ ! -f "$COMPACT_MARKER" ]; then

  # Quick time check FIRST — skip config parsing if before earliest default remind time
  # Use configured timezone via python (TZ-aware)
  TZ_NAME="$(python3 -c "
import yaml
try:
    c = yaml.safe_load(open('$CONFIG'))
    print(c.get('locale', {}).get('timezone', 'Asia/Shanghai'))
except:
    print('Asia/Shanghai')
" 2>/dev/null || echo 'Asia/Shanghai')"

  NOW_MIN=$(python3 -c "
import datetime, zoneinfo
now = datetime.datetime.now(zoneinfo.ZoneInfo('$TZ_NAME'))
print(now.hour * 60 + now.minute)
" 2>/dev/null || echo $(( $(date +%H) * 60 + $(date +%-M) )))

  # Default earliest remind: 12:00 (720 min). Skip if clearly before that.
  if [ "$NOW_MIN" -ge 480 ] && [ -f "$CONFIG" ]; then
    DIGEST_CFG="$(python3 -c "
import yaml
try:
    c = yaml.safe_load(open('$CONFIG'))
    d = c.get('digest', {})
    print(d.get('default_scope', ''))
    print(d.get('auto_generate', False))
    for t in d.get('remind_at', []):
        print('remind:' + str(t))
except:
    pass
" 2>/dev/null || true)"

    DEFAULT_SCOPE=""
    AUTO_GENERATE="False"
    REMIND_TIMES=()

    while IFS= read -r line; do
      if [[ "$line" == remind:* ]]; then
        REMIND_TIMES+=("${line#remind:}")
      elif [ -z "$DEFAULT_SCOPE" ]; then
        DEFAULT_SCOPE="$line"
      elif [ "$AUTO_GENERATE" = "False" ]; then
        AUTO_GENERATE="$line"
      fi
    done <<< "$DIGEST_CFG"

    # Check: current time >= any remind_at time (first session after that time triggers)
    PAST_REMIND=false
    for rtime in "${REMIND_TIMES[@]}"; do
      RHOUR="${rtime%%:*}"
      RMIN="${rtime##*:}"
      RTOTAL=$(( 10#$RHOUR * 60 + 10#$RMIN ))
      if [ "$NOW_MIN" -ge "$RTOTAL" ]; then
        PAST_REMIND=true
        break
      fi
    done

    if [ "$PAST_REMIND" = true ] && [ -n "$DEFAULT_SCOPE" ]; then
      TODAY="$(TZ=$TZ_NAME date +%Y-%m-%d 2>/dev/null || date +%Y-%m-%d)"
      JOURNAL="$PLUME_ROOT/data/journal/${TODAY}.md"
      HINT_MARKER="$PLUME_ROOT/data/.digest-hint-$TODAY"

      if [ ! -f "$JOURNAL" ] && [ ! -f "$HINT_MARKER" ]; then
        HAS_ACTIVITY=false
        if [ -d "$CLAUDE_PROJECTS" ]; then
          for projdir in "$CLAUDE_PROJECTS"/*/; do
            dirname="$(basename "$projdir")"
            if echo "$dirname" | grep -qi "$DEFAULT_SCOPE"; then
              if find "$projdir" -maxdepth 1 -name "*.jsonl" -newermt "$TODAY" -print -quit 2>/dev/null | grep -q .; then
                HAS_ACTIVITY=true
                break
              fi
            fi
          done
        fi

        if [ "$HAS_ACTIVITY" = true ]; then
          touch "$HINT_MARKER"
          if [ "$AUTO_GENERATE" = "True" ]; then
            CONTEXT_PARTS+=("[DIGEST-AUTO] Auto-generate daily report now. Scope: $DEFAULT_SCOPE")
          else
            CONTEXT_PARTS+=("[DIGEST-HINT] Active sessions today (scope: $DEFAULT_SCOPE), no daily report yet.")
          fi
        fi
      fi
    fi
  fi
fi

# --- Output ---
if [ ${#CONTEXT_PARTS[@]} -eq 0 ]; then
  echo '{}'
  exit 0
fi

FULL_MSG="$(printf '%s\n' "${CONTEXT_PARTS[@]}")"

ESCAPED="$(printf '%s' "$FULL_MSG" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '%s' "$FULL_MSG" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | awk '{printf "%s\\n", $0}')"

cat <<EOF
{
  "hookSpecificOutput": {
    "additionalContext": $ESCAPED
  }
}
EOF
